    <p>
        Here is the best rank 30 approximation for the image. Can you tell what the image is?
        <image source="./buzz/rank_30.png" workspace="5in" width="70%">
            <shortdescription>Rank 30 approximation of image.</shortdescription>
        </image>
    </p>
  </page>

