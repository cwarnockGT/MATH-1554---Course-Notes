<handout xml:id="handout-section-6-4-gram-schmidt">
  <title>6.4 Gram–Schmidt and QR Decomposition</title>

  <page xml:id="p-6-4-overview">
    <title>Overview</title>

    <objectives xml:id="obj-6-4-topics-goals">
      <title>Topics</title>
      <ul>
        <li>The Gram–Schmidt Process</li>
        <li>The QR decomposition</li>
      </ul>
      </objectives>

      <objectives>
      <title>Goals</title>
      <ul>
        <li>Apply Gram–Schmidt and QR decomposition to construct orthogonal or orthonormal bases.</li>
        <li>Compute the QR factorization of a matrix.</li>
      </ul>
      </objectives>

      <p><em>Motivating Question</em></p>
      <p>
        Identify an orthogonal basis for the subspace spanned by:
      </p>

      <me>
        \vec x_1=\begin{bmatrix}1\\1\\1\\1\end{bmatrix},\quad
        \vec x_2=\begin{bmatrix}0\\1\\1\\1\end{bmatrix},\quad
        \vec x_3=\begin{bmatrix}0\\0\\1\\1\end{bmatrix}.
      </me>

      <p><nbsp/></p>

    <example xml:id="ex-6-4-orth-basis" workspace="true">
      <statement>
        <p>
          The vectors below span a subspace <m>W\subset\mathbb{R}^4</m>. Construct an orthogonal basis.
        </p>
        <me>
          \vec x_1=\begin{bmatrix}1\\1\\1\\1\end{bmatrix},\quad
          \vec x_2=\begin{bmatrix}0\\1\\1\\1\end{bmatrix},\quad
          \vec x_3=\begin{bmatrix}0\\0\\1\\1\end{bmatrix}.
        </me>
      </statement>
    </example>
  </page>


  <page xml:id="p-6-4-gram-schmidt">
    <title>The Gram–Schmidt Process</title>

    <theorem xml:id="thm-gram-schmidt">
      <title>The Gram–Schmidt Construction</title>
      <statement>
        <p>
          Given a basis <m>\{\vec x_1,\dots,\vec x_p\}</m> for a subspace <m>W</m>, define:
        </p>
        <me>
          \vec v_1=\vec x_1,
        </me>
        <me>
          \vec v_2 = \vec x_2 - \frac{\vec x_2\cdot\vec v_1}{\vec v_1\cdot\vec v_1}\vec v_1,
        </me>
        <me>
          \vec v_3 = \vec x_3 - \frac{\vec x_3\cdot\vec v_1}{\vec v_1\cdot\vec v_1}\vec v_1
                     - \frac{\vec x_3\cdot\vec v_2}{\vec v_2\cdot\vec v_2}\vec v_2,
        </me>
        <p>and so on.</p>
        <me>
          \vec v_p = \vec x_p - \sum_{k=1}^{p-1}
          \frac{\vec x_p\cdot\vec v_k}{\vec v_k\cdot\vec v_k}\vec v_k.
        </me>

        <p>
          Then <m>\{\vec v_1,\dots,\vec v_p\}</m> is an orthogonal basis for <m>W</m>.
        </p>
      </statement>
    </theorem>

    <p><nbsp/></p>
  </page>


  <page xml:id="p-6-4-gs-geometry">
    <title>Geometric Interpretation</title>

    <image xml:id="img-6-4-gs-geom">
      <latex-image>
        <latex>
\tdplotsetmaincoords{70}{40}
\begin{tikzpicture}[scale=1.5,
    axis/.style={->,black,-stealth}, 
    vectorP/.style={-stealth,black, thick},
    vectorV/.style={-stealth,DarkBlue,very thick},
    vectorX/.style={-stealth,DarkRed,very thick},
    dsline/.style={black,dashed},
    perpline/.style={DarkBlue, thin},
    tdplot_main_coords
    ]

  % plane
  \filldraw[draw=DarkBlue!20,fill=DarkBlue!05]
    (-1,-2,0) -- (3,-2,0) -- (3,4,0) -- (-1,4,0) -- cycle;

  \coordinate (O) at (0,0,0);
  \coordinate (X1) at (2,0,0);
  \coordinate (X2) at (1,2.6,0);
  \coordinate (X3) at (1.9,1,1.8);
  \coordinate (P) at (1.9,1,0);

  \draw[vectorX] (O)--(X1) node[below]{$\vec x_1=\vec v_1$};
  \draw[vectorX] (O)--(X2) node[right]{$\vec x_2$};
  \draw[vectorX] (O)--(X3) node[right]{$\vec x_3$};

  \draw[vectorV] (O)--(0,2.6,0) node[above]{$\vec v_2$};
  \draw[vectorV] (O)--(0,0,1.8) node[above]{$\vec v_3$};

  \draw[vectorP] (O)--(P) node[right]{proj$_{W_2}\vec x_3$};

  \draw[dsline] (P)--(X3);

  \draw[dsline] (-3,0,0)--(4,0,0) node[below]{$W_1$};

  \draw[DarkBlue] (.5,-1.8,0) node[above]{$W_2$};

\end{tikzpicture}
        </latex>
      </latex-image>
      <shortdescription>Geometric view of Gram–Schmidt orthogonalization.</shortdescription>
      <description>
        Vectors <m>\vec x_1,\vec x_2,\vec x_3</m> are processed to produce orthogonal vectors
        <m>\vec v_1,\vec v_2,\vec v_3</m> via subtraction of projections.
      </description>
    </image>

    <p>
      Gram–Schmidt successively removes the components of each vector in the span of earlier ones.
    </p>
  </page>


  <page xml:id="p-6-4-orthonormal">
    <title>Orthonormal Bases</title>

    <definition xml:id="def-orthonormal">
      <title>Orthonormal Basis</title>
      <statement>
        <p>
          A set of vectors is an <em>orthonormal basis</em> if the vectors are mutually orthogonal and all have
          length 1.
        </p>
      </statement>
    </definition>

    <p><nbsp/></p>

    <example xml:id="ex-6-4-orthonormalize" workspace="true">
      <title>Example</title>
      <statement>
        <p>
          The vectors below form an orthogonal basis for a subspace <m>W</m>. Construct an
          orthonormal basis for <m>W</m>.
        </p>

        <me>
          \vec v_1=\begin{bmatrix}3\\2\\0\end{bmatrix},\quad
          \vec v_2=\begin{bmatrix}-2\\3\\1\end{bmatrix}.
        </me>
      </statement>
    </example>
  </page>


  <page xml:id="p-6-4-qr-factorization">
    <title>The QR Factorization</title>

    <theorem xml:id="thm-qr">
      <title>QR Factorization</title>
      <statement>
        <p>
          If <m>A</m> is an <m>m\times n</m> matrix with linearly independent columns, then <m>A</m> has
          a QR factorization:
        </p>

        <me>
          A = QR,
        </me>

        <p>where:</p>

        <ul>
          <li><m>Q</m> is <m>m\times n</m> with orthonormal columns spanning <m>\operatorname{Col}(A)</m>,</li>
          <li><m>R</m> is <m>n\times n</m>, upper triangular, with positive diagonal entries.</li>
        </ul>
      </statement>
    </theorem>

    <p><nbsp/></p>

    <p>
      We omit here the dependent-columns case; students need not know the general criteria for existence.
    </p>
  </page>


  <page xml:id="p-6-4-example-qr">
    <title>Example: QR Factorization</title>

    <example xml:id="ex-6-4-qr-example" workspace="true">
      <title>Example</title>
      <statement>
        <p>
          Compute the QR decomposition of:
        </p>

        <me>
          A=\begin{bmatrix}
            3 \amp -2\\
            2 \amp 3\\
            0 \amp 1
          \end{bmatrix}.
        </me>
      </statement>
    </example>
  </page>

</handout>