<page xml:id="p-6-5-def-ls">
    <title>Least Squares Solution</title>

    <example xml:id="ex-6-6-inconsistent" >
      <introduction>
        <p>
            Suppose we want to construct a line of the form <m>y=mx+b</m> that best fits the data below.
        </p>
        <image xml:id="img-6-5-scatter" width = "30%">
          <latex-image>
            <latex>
\begin{tikzpicture}
  \draw[gray] (-2,0) grid (3,3); 
  \draw[->] (-2.5,0) -- (3.5,0) node[below]{$x$};
  \draw[->] (0,-.5) -- (0,3.5) node[left]{$y$};
  \foreach \x/\y in {-2/0,-1/2,3/3}
    \filldraw (\x,\y) circle (.2em); 
  \foreach \x in {-2,...,-1} {
    \draw[thin] (\x,0.1) -- (\x,-.1) node[anchor=north] {\small$\x$};
  }
  \foreach \x in {1,...,3} {
    \draw[thin] (\x,0.1) -- (\x,-.1) node[anchor=north] {\small$\x$};
  }
  \foreach \y in {1,...,3} {
    \draw[thin] (-0.1,\y) -- (0.1,\y) node[anchor=west] {\small$\y$};
  }
\end{tikzpicture}
            </latex>
          </latex-image>
          <shortdescription>A 2D scatter plot showing the four points (-2,0), (-1,2), and (3,3) used for linear least squares fitting.</shortdescription>
        </image>

    </introduction>
    <task workspace="2in">
        <statement>
            <p>
                Find a system of equations <m>A\vec x = \vec b</m> that can be used to solve for <m>m</m> and <m>b</m>.
            </p>
        </statement>
    </task>
    <task workspace="2in">
        <statement>
            <p>
                Is the system found in (a) consistent?
            </p>
        </statement>
    </task>
    <task workspace="3in">
        <statement>
            <p>
                Find the vector <m>\widehat b = \proj_{\Col(A)}\vec b</m>. (Note that the columns of <m>A</m> should already be orthogonal. What would be required if they weren't?)
            </p>
        </statement>
    </task>
    <task workspace="2in">
        <statement>
            <p>
                Find the <em>least squares solution</em> to <m>A\vec x = \vec b</m>.
            </p>
        </statement>
    </task>
    <task>
        <statement>
            <p>
                What does the least squares solution found in (d) mean?
            </p>
        </statement>
    </task>
    </example>

    <p><nbsp/></p>
  </page>